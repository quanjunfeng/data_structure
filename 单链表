'''
#include <cstdio>
#include<cstdlib>

typedef struct LNode
{
	int data;
	struct LNode* next;
}LinkNode;

void InitList(LinkNode *&L)
{
	L = (LinkNode*)malloc(sizeof(LinkNode));
	L->next = NULL;
}

// 头插法 
void CreateListF(LinkNode*&L, int a[], int n)
{
	LinkNode* s;
	for(int i=0;i<n;i++)
	{
		s = (LinkNode*)malloc(sizeof(LinkNode));
		s->data = a[i];
		s->next = L->next;
		L->next = s;
	}
}

//尾插法
void CreateListR(LinkNode*&L, int a[], int n) 
{
	LinkNode* s, *r; // r指向尾节点，方便最后一个节点指向新创建的节点
	r = L;
	for(int i=0;i<n;i++) 
	{
		s = (LinkNode*)malloc(sizeof(LinkNode));
		s->data = a[i];
		r->next = s;
		r = s;
	}
	r->next = NULL;
}

//释放链表空间 
void DestroyList(LinkNode*&L) 
{
	LinkNode *pre, *q;
	pre = L; q = pre->next;
	while(q!=NULL)
	{
		free(pre);
		pre = q;
		q = pre->next;
	}
	free(q);
}

//判断链表是否为空
bool ListEmpty(LinkNode*L) 
{
	return (L->next==NULL);
}

// 求单链表的长度
int ListLength(LinkNode*L) 
{
	int length=0;
	LinkNode* q = L->next;
	while(q!=NULL)
	{
		length++;
		q = q->next; 
	}
	return length;
}

// 输出单链表
void Display(LinkNode *L) 
{
	LinkNode*nt = L->next;
	while(nt!=NULL)
	{
		printf("%d ",nt->data);
		nt = nt->next;
	}
	printf("\n");
};

//求单链表L中第i个的数据元素
int GetElem(LinkNode* L, int i) 
{
	i--;
	int pos=0;
	LinkNode* p = L->next;
	while(pos<i && p!=NULL)
	{
		pos++; p=p->next;
	}
	if(p==NULL) return -1;
	else return p->data;
	
}

//按元素查找，返回位置
int LocateElem(LinkNode*L, int e) 
{
	int pos=1;
	LinkNode*p = L->next;
	int found = 0;
	while(p!=NULL)
	{
		if(p->data==e)
		{
			found = 1;
			break;
		}else{
			p = p->next;
			pos++;
		}
	}
	if(found) return pos;
	else return 0;
}

//在第i位置插入数据元素
bool ListInsert(LinkNode*&L, int i, int e) 
{

	if(i<1) return false;
	int pos = 1;
	LinkNode* q = L;
	while(pos<i && q!=NULL)
	{
		q = q->next; pos++;
	}
	if(q==NULL) return false;
	LinkNode* s = (LinkNode*)malloc(sizeof(LinkNode));
	s->data = e;
	s->next = q->next;
	q->next = s;
	return true;
}

//删除第i个数据元素
bool ListDelete(LinkNode *&L,int i) 
{
	if(i<1)  return false;
	int pos=1;
	LinkNode* q = L;
	while(pos<i && q!=NULL)
	{
		q=q->next; pos++;
	}
	if(q==NULL) return false;
	LinkNode* temp = q->next;
	if(temp==NULL) return false;
	q->next = q->next->next;
	free(temp);
	return true;
}

int main()
{
	int a[20];
	for(int i=0;i<20;i++) a[i] = i+1;
	LinkNode* L; //这是头节点 
	InitList(L);
	CreateListR(L, a, 10);
	Display(L);
	printf("List length: %d\n", ListLength(L));
	printf("第i个元素是: %d\n",GetElem(L, 5)); 
	printf("元素5是单链表中第%d个\n", LocateElem(L, 5));
	if(int a=ListInsert(L, 11 ,11))
	{
		printf("第11个位置插入11成功,新的链表: ", a);
		Display(L);
	}
	else printf("插入位置不合法\n");
	if(ListDelete(L,11))
	{
		printf("第11个元素已删除,新的单链表: "); 
		Display(L);
	}else{
		printf("删除位置不合法");
	}
}
